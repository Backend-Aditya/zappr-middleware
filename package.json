{
  "name": "zappr-middleware",
  "type": "module",
  "version": "1.0.0",
  "description": "Shopify ↔ Zappr delivery integration middleware for Unived",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node --watch server.js",
    "dev:worker": "node --watch src/queue/workers/orderPushWorker.js",
    "start": "pm2-runtime start ecosystem.config.cjs --env production",
    "start:local": "pm2 start ecosystem.config.cjs",
    "migrate": "drizzle-kit migrate",
    "migrate:generate": "drizzle-kit generate",
    "migrate:push": "drizzle-kit push",
    "migrate:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.11",
    "bullmq": "^5.79.1",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "ky": "^2.0.2",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "pm2": "^6.0.14",
    "rate-limit-redis": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "prettier": "^3.8.5",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  }
}
