NODE_ENV=development
PORT=3000

# Shopify — Dev Dashboard app (client credentials grant, tokens auto-refresh every 24h)
# Setup: dev.shopify.com → Apps → Create app → Get Client ID + Secret → Install on store
# NOTE: grant only works for stores in the app's own organization.
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Collaborator/client stores: create a custom app in the store admin
# (Settings → Apps and sales channels → Develop apps), paste its Admin API
# access token here — client credentials grant is then skipped entirely.
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_APP_PROXY_SECRET=
SHOPIFY_WEBHOOK_SECRET=

# Zappr — backed by EasyEcom's API in live mode
ZAPPR_MODE=mock
ZAPPR_BASE_URL=https://api.easyecom.io
ZAPPR_API_KEY=
ZAPPR_X_API_KEY=
ZAPPR_MARKETPLACE_ID=10
ZAPPR_CARRIER_ID=
# Shared secret in webhook URL given to Zappr team: /webhooks/zappr/tracking?token=<this>
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ZAPPR_WEBHOOK_TOKEN=
ZAPPR_MOCK_URL=http://localhost:4001
ZAPPR_MOCK_API_KEY=MOCK_ZAPPR_KEY
ZAPPR_MOCK_X_API_KEY=MOCK_ZAPPR_X_API_KEY
ZAPPR_SURCHARGE_AMOUNT=49
ZAPPR_HOLIDAYS=

# PostgreSQL
DATABASE_URL=postgresql://zappr:zappr@postgres:5432/zappr_middleware

# Redis
REDIS_URL=redis://redis:6379

# App
LOG_LEVEL=info
ZAPPR_STOCK_TTL_SECONDS=120
